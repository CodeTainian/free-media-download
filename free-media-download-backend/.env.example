SAVEBOLT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
SAVEBOLT_MAX_BATCH_ITEMS=10
SAVEBOLT_MAX_FILE_BYTES=2147483648
SAVEBOLT_MAX_BUNDLE_BYTES=4294967296
SAVEBOLT_MAX_DURATION_SECONDS=21600
SAVEBOLT_PROBE_TIMEOUT_SECONDS=30
SAVEBOLT_ITEM_TIMEOUT_SECONDS=3600
SAVEBOLT_WORKER_CONCURRENCY=2
SAVEBOLT_JOB_TTL_SECONDS=1800
SAVEBOLT_CLEANUP_INTERVAL_SECONDS=300
SAVEBOLT_PROBE_CACHE_TTL_SECONDS=300
SAVEBOLT_PROBE_CACHE_MAX_ENTRIES=256
SAVEBOLT_YTDLP_JS_RUNTIME=node
# Automatically create a temporary anonymous Chromium session for public Douyin links.
SAVEBOLT_ANONYMOUS_BROWSER_COOKIES=true
# Match Chromium's TLS/browser request fingerprint when yt-dlp reuses the session.
SAVEBOLT_BROWSER_IMPERSONATE=chrome
SAVEBOLT_BROWSER_SESSION_TTL_SECONDS=1200
SAVEBOLT_BROWSER_COOKIE_WAIT_SECONDS=20
# Optional when Chromium/Chrome is not auto-detected.
# SAVEBOLT_BROWSER_BINARY=/absolute/path/to/chromium
# Container-only fallback when the Chromium sandbox is unavailable; keep false on normal hosts.
# SAVEBOLT_BROWSER_NO_SANDBOX=false
# Optional local-only server session. Supported values include chrome, firefox, and safari.
# The API process must run as the same OS user that owns the selected browser profile.
# SAVEBOLT_COOKIES_FROM_BROWSER=chrome
# Apply the configured cookie source only to these platform keys. Keep this list minimal.
# SAVEBOLT_COOKIE_PLATFORMS=youtube,douyin,ixigua
# Container alternative: mount a fresh Netscape-format file read-only. Do not configure both sources.
# SAVEBOLT_COOKIES_FILE=/run/secrets/savebolt.cookies.txt
# Some anti-bot sessions require the exact user agent used when the cookies were created.
# SAVEBOLT_YTDLP_USER_AGENT=Mozilla/5.0 ...
# Optional operator-managed static egress proxy for region/IP restrictions.
# SAVEBOLT_YTDLP_PROXY=http://127.0.0.1:8080
# Optional absolute path; local development auto-detects system FFmpeg or imageio-ffmpeg.
# SAVEBOLT_FFMPEG_BINARY=/absolute/path/to/ffmpeg
