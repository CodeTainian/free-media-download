# Local development uses the same-origin /api/v1 proxy by default.
SAVEBOLT_API_ORIGIN=http://127.0.0.1:8000
# Set this only when browsers should call a separately hosted public API directly.
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Product preview flags. These do not enable missing backend capabilities.
NEXT_PUBLIC_SHOW_PRICING_PREVIEW=true
NEXT_PUBLIC_ENABLE_UPLOAD=false
