NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
SAVEBOLT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
SAVEBOLT_MAX_BATCH_ITEMS=10
SAVEBOLT_MAX_FILE_BYTES=2147483648
SAVEBOLT_MAX_BUNDLE_BYTES=4294967296
SAVEBOLT_MAX_DURATION_SECONDS=21600
SAVEBOLT_PROBE_TIMEOUT_SECONDS=30
SAVEBOLT_ITEM_TIMEOUT_SECONDS=3600
SAVEBOLT_WORKER_CONCURRENCY=2
SAVEBOLT_JOB_TTL_SECONDS=1800
SAVEBOLT_CLEANUP_INTERVAL_SECONDS=300
SAVEBOLT_PROBE_CACHE_TTL_SECONDS=300
SAVEBOLT_PROBE_CACHE_MAX_ENTRIES=256
SAVEBOLT_YTDLP_JS_RUNTIME=node
# Optional local-only YouTube session. Supported values include chrome, firefox, and safari.
# The API process must run as the same OS user that owns the selected browser profile.
# SAVEBOLT_COOKIES_FROM_BROWSER=chrome
# Optional absolute path; local development auto-detects system FFmpeg or imageio-ffmpeg.
# SAVEBOLT_FFMPEG_BINARY=/absolute/path/to/ffmpeg
